[bootstrap]
main_collection = /sample/main.collectionc

[project]
title = Flow
version = 1.0.0
dependencies#0 =

[library]
include_dirs = flow

[display]
width = 960
height = 640
high_dpi = 1

[graphics]
max_font_batches = 512

[input]
game_binding = /input/game.input_binding

[script]
shared_state = 1

[android]
input_method = HiddenInputField

[html5]
scale_mode = stretch
